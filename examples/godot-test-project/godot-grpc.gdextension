[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.6
reloadable = true

[libraries]
; Dev paths: load straight from the workspace target dir (relative to this file).
linux.debug.x86_64 = "res://../../target/debug/libgodot_grpc.so"
linux.release.x86_64 = "res://../../target/release/libgodot_grpc.so"
macos.debug = "res://../../target/debug/libgodot_grpc.dylib"
macos.release = "res://../../target/release/libgodot_grpc.dylib"
