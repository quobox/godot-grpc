root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# GDScript is tab-indented (Godot convention).
[*.gd]
indent_style = tab

[*.{yml,yaml,json}]
indent_size = 2

# buf formats protos with a 2-space indent.
[*.proto]
indent_size = 2

# Preserve hard line breaks (two trailing spaces) in Markdown.
[*.md]
trim_trailing_whitespace = false
